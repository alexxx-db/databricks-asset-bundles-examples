.DS_Store
Thumbs.db
Desktop.ini
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Dd]esktop.ini

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ─── Secrets / Credentials ──────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
credentials*
